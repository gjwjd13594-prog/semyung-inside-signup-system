generator client {
  provider = "prisma-client-js"
  output   = "../server/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique @db.VarChar(20)
  email         String         @unique
  password      String
  nickname      String         @unique @db.VarChar(20)
  phone         String?        @unique @db.VarChar(20)
  carrier       String?        @db.VarChar(20)
  phoneVerified Boolean        @default(false)
  profileImage  String?
  role          UserRole       @default(USER)
  isVerified    Boolean        @default(false)
  isBanned      Boolean        @default(false)
  banReason     String?
  banUntil      DateTime?
  level         Int            @default(1)
  exp           Int            @default(0)
  lastLoginAt         DateTime?
  photoStatus         PhotoStatus @default(NONE)
  photoRejectReason   String?
  datingVisible       Boolean     @default(true)
  photos              ProfilePhoto[]
  roomMemberships     RoomMember[]    @relation("RoomMembers")
  sentMessages        ChatMessage[]   @relation("SentMessages")
  hostedMeetups       Meetup[]        @relation("HostedMeetups")
  joinRequests        JoinRequest[]   @relation("JoinRequests")
  posts               Post[]
  comments      Comment[]
  votes         Vote[]
  reports       Report[]
  notifications Notification[]
  bookmarks     Bookmark[]
  auditLogs     AdminAuditLog[] @relation("AdminActor")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model PhoneVerification {
  id         Int       @id @default(autoincrement())
  phone      String    @db.VarChar(20)
  carrier    String    @db.VarChar(20)
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  verifiedAt DateTime?
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
}

model AdminPrivacyAccessLog {
  id            Int      @id @default(autoincrement())
  adminId       Int
  adminUsername String   @db.VarChar(20)
  action        String   @db.VarChar(50)
  targetUserId  Int?
  reason        String?  @db.VarChar(200)
  ip            String?  @db.VarChar(45)
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetUserId, createdAt])
}

enum UserRole {
  USER
  MANAGER
  ADMIN
}

model Board {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String   @db.VarChar(30)
  description String?
  icon        String?
  isAdult     Boolean  @default(false)
  isAnonymous Boolean  @default(false)
  isHot       Boolean  @default(false)
  sortOrder   Int      @default(0)
  posts       Post[]
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  Int
  createdAt   DateTime @default(now())
}

model Category {
  id        Int     @id @default(autoincrement())
  name      String  @db.VarChar(20)
  sortOrder Int     @default(0)
  boards    Board[]
}

model Post {
  id           Int         @id @default(autoincrement())
  title        String      @db.VarChar(100)
  content      String      @db.Text
  author       User?       @relation(fields: [authorId], references: [id])
  authorId     Int?
  authorNick   String      @db.VarChar(20)
  board        Board       @relation(fields: [boardId], references: [id])
  boardId      Int
  isAnonymous  Boolean     @default(false)
  isPinned     Boolean     @default(false)
  isNotice     Boolean     @default(false)
  isDeleted    Boolean     @default(false)
  isAdult      Boolean     @default(false)
  viewCount    Int         @default(0)
  upvotes      Int         @default(0)
  downvotes    Int         @default(0)
  commentCount Int         @default(0)
  images       PostImage[]
  comments     Comment[]
  votes        Vote[]
  reports      Report[]
  tags         PostTag[]
  bookmarks    Bookmark[]
  ip           String?     @db.VarChar(45)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([boardId, createdAt])
  @@index([upvotes])
}

model PostImage {
  id        Int    @id @default(autoincrement())
  post      Post   @relation(fields: [postId], references: [id])
  postId    Int
  url       String
  sortOrder Int    @default(0)
}

model Comment {
  id          Int       @id @default(autoincrement())
  content     String    @db.VarChar(1000)
  author      User?     @relation(fields: [authorId], references: [id])
  authorId    Int?
  authorNick  String    @db.VarChar(20)
  post        Post      @relation(fields: [postId], references: [id])
  postId      Int
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  parentId    Int?
  replies     Comment[] @relation("CommentReplies")
  isAnonymous Boolean   @default(false)
  isDeleted   Boolean   @default(false)
  upvotes     Int       @default(0)
  downvotes   Int       @default(0)
  votes       Vote[]
  reports     Report[]
  ip          String?   @db.VarChar(45)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([postId, createdAt])
}

model Vote {
  id        Int       @id @default(autoincrement())
  user      User      @relation(fields: [userId], references: [id])
  userId    Int
  post      Post?     @relation(fields: [postId], references: [id])
  postId    Int?
  comment   Comment?  @relation(fields: [commentId], references: [id])
  commentId Int?
  type      VoteType
  createdAt DateTime  @default(now())

  @@unique([userId, postId])
  @@unique([userId, commentId])
}

enum VoteType {
  UP
  DOWN
}

model Report {
  id         Int          @id @default(autoincrement())
  reporter   User         @relation(fields: [reporterId], references: [id])
  reporterId Int
  post       Post?        @relation(fields: [postId], references: [id])
  postId     Int?
  comment    Comment?     @relation(fields: [commentId], references: [id])
  commentId  Int?
  reason     ReportReason
  detail     String?
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
}

enum ReportReason {
  SPAM
  OBSCENE
  ILLEGAL
  HATE
  PERSONAL_INFO
  COPYRIGHT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

model Notification {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  type      String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  post      Post     @relation(fields: [postId], references: [id])
  postId    Int
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model Tag {
  id    Int       @id @default(autoincrement())
  name  String    @unique @db.VarChar(20)
  posts PostTag[]
}

model PostTag {
  post   Post @relation(fields: [postId], references: [id])
  postId Int
  tag    Tag  @relation(fields: [tagId], references: [id])
  tagId  Int

  @@id([postId, tagId])
}

model BannedWord {
  id    Int    @id @default(autoincrement())
  word  String @unique
  level Int    @default(1)
}

enum PhotoStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

model ProfilePhoto {
  id        String      @id @default(cuid())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  key       String
  url       String
  sha256    String
  phash     String
  isPrimary Boolean     @default(false)
  order     Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([sha256])
}

enum RoomKind {
  DM
  MEETUP
  GROUP
}

enum JoinStatus {
  PENDING
  APPROVED
  REJECTED
}

model ChatRoom {
  id        String        @id @default(cuid())
  kind      RoomKind
  title     String
  refId     String?
  members   RoomMember[]
  messages  ChatMessage[]
  createdAt DateTime      @default(now())

  @@index([kind, refId])
}

model RoomMember {
  id         String   @id @default(cuid())
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId     String
  user       User     @relation("RoomMembers", fields: [userId], references: [id])
  userId     Int
  isHost     Boolean  @default(false)
  lastReadAt DateTime @default(now())
  joinedAt   DateTime @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  sender    User?    @relation("SentMessages", fields: [senderId], references: [id])
  senderId  Int?
  content   String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
}

model Meetup {
  id        String        @id @default(cuid())
  title     String
  place     String
  time      String
  maxN      Int
  tag       String
  host      User          @relation("HostedMeetups", fields: [hostId], references: [id])
  hostId    Int
  ended     Boolean       @default(false)
  requests  JoinRequest[]
  createdAt DateTime      @default(now())
}

model JoinRequest {
  id          String     @id @default(cuid())
  meetup      Meetup     @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  meetupId    String
  applicant   User       @relation("JoinRequests", fields: [applicantId], references: [id])
  applicantId Int
  status      JoinStatus @default(PENDING)
  createdAt   DateTime   @default(now())

  @@unique([meetupId, applicantId])
}

model AdminAuditLog {
  id        Int      @id @default(autoincrement())
  actor     User     @relation("AdminActor", fields: [actorId], references: [id])
  actorId   Int
  action    String   @db.VarChar(50)
  targetId  String?
  memo      String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}
